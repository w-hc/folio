{
  "name": "folio-serve",
  "version": "1.0.0",
  "description": "A mobile-friendly file browser with Markdown rendering",
  "bin": {
    "folio": "./server.js"
  },
  "files": [
    "server.js",
    "html-engine.js",
    "markdown-it-renderer.js",
    "highlight.js",
    "outline.js",
    "dist.css"
  ],
  "keywords": [
    "file-browser",
    "markdown",
    "katex",
    "math",
    "shiki",
    "syntax-highlighting",
    "tailscale"
  ],
  "scripts": {
    "build": "tailwindcss -i input.css -o dist.css --minify",
    "dev": "concurrently -P -k \"node --watch server.js --dev {@}\" \"tailwindcss -i input.css -o dist.css --watch\" --",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "dependencies": {
    "@traptitech/markdown-it-katex": "^3.6.0",
    "katex": "^0.16.11",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "shiki": "^4.0.2",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.4"
  }
}
